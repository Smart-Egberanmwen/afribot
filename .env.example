# =============================================================================
# AFRIBOT AGENCY OS — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in all values
# =============================================================================

# ---- APP CONFIG ----
NODE_ENV=development
API_PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# ---- DATABASE (Supabase) ----
# Get from: https://app.supabase.com → Project Settings → API
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
SUPABASE_URL=https://[PROJECT-ID].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret

# ---- REDIS ----
# For local dev: redis://localhost:6379
# For Railway/Render: provided in dashboard
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ---- AUTHENTICATION (Supabase Auth or Clerk) ----
# If using Clerk: https://clerk.com/
CLERK_SECRET_KEY=sk_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ---- WHATSAPP / 360DIALOG ----
# Agency partner API key from 360Dialog
# Apply at: https://www.360dialog.com/partners
DIALOG360_PARTNER_TOKEN=your-partner-token
DIALOG360_PARTNER_ID=your-partner-id
DIALOG360_API_BASE=https://waba.360dialog.io
WEBHOOK_VERIFY_TOKEN=your-custom-webhook-verify-token
WEBHOOK_SECRET=your-webhook-hmac-secret

# ---- AI PROVIDERS ----
# Primary: Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Secondary: OpenAI GPT-4o (fallback)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# Optional: Grok via xAI
GROK_API_KEY=xai-...
# Optional: OpenRouter (unified gateway)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- VECTOR DATABASE (for RAG) ----
# Use Supabase pgvector (already included) or Pinecone
PGVECTOR_ENABLED=true
# Optional external vector DB
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=afribot-knowledge

# ---- PAYMENTS (Paystack) ----
# https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret

# ---- FILE STORAGE (Supabase Storage) ----
STORAGE_BUCKET_NAME=afribot-files
MAX_UPLOAD_SIZE_MB=10

# ---- EMAIL (Resend) ----
# https://resend.com — free tier: 3000/month
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com

# ---- MONITORING & LOGGING ----
# https://sentry.io
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# Log level: error | warn | info | debug
LOG_LEVEL=info

# ---- RATE LIMITING ----
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100
WEBHOOK_RATE_LIMIT_MAX=500

# ---- AGENCY CONFIG ----
AGENCY_NAME=AfriBot Agency
AGENCY_EMAIL=admin@youragency.com
AGENCY_WHATSAPP=+2348000000000
SUPER_ADMIN_EMAIL=admin@youragency.com
DEFAULT_CURRENCY=NGN
DEFAULT_TIMEZONE=Africa/Lagos
DEFAULT_LOCALE=en-NG

# ---- FEATURE FLAGS ----
FEATURE_VOICE_ENABLED=false
FEATURE_INSTAGRAM_ENABLED=false
FEATURE_SOCIAL_CONTENT=true
FEATURE_WHITE_LABEL=false

# ---- EMAIL — TRANSACTIONAL (Resend) ----
# Sign up free at resend.com — 3,000 emails/month free
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# ---- EMAIL — INBOUND (Postmark) ----
# Sign up at postmark.com — needed to receive customer emails
# After setup, point your MX records or use inbound addresses
POSTMARK_INBOUND_TOKEN=your-postmark-server-token
# Each client gets a support address like: support@clientslug.yourdomain.com
EMAIL_INBOUND_DOMAIN=mail.yourdomain.com
